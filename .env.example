# Google Cloud — path to the service account JSON keyfile
GOOGLE_APPLICATION_CREDENTIALS=gcp_keyfile.json

# BigQuery project and dataset identifiers
GCP_PROJECT_ID=your-gcp-project-id
BQ_RAW_DATASET=raw
BQ_ANALYTICS_DATASET=analytics

# Optional: CoinGecko API key (free tier works without one; key raises rate limit)
COINGECKO_API_KEY=
